# pandavas — environment template
# Copy this file to .env and fill in your own keys. NEVER commit the real .env.
# pandavas runs on free inference tiers by design; supply whichever provider(s) you use.

# --- LLM inference (pick the provider(s) you use) ---
# Groq (free tier)
GROQ_API_KEY=

# Google Gemini (free tier)
GEMINI_API_KEY=

# OpenRouter (optional — single key, many models)
OPENROUTER_API_KEY=

# --- Model selection (pin exact model strings; never use "latest") ---
# Example values — replace with the exact model IDs you intend to pin.
PANDAVAS_RESEARCH_MODEL=
PANDAVAS_WORKER_MODEL=
PANDAVAS_JUDGE_MODEL=

# --- Optional: external search for the Research agent ---
TAVILY_API_KEY=

# --- Run tuning (optional; sensible defaults applied if blank) ---
# PANDAVAS_TEMPERATURE=0
# PANDAVAS_MAX_ITERATIONS=6
